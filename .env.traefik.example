# ===========================================
# NETLOOP - TRAEFIK CONFIGURATION
# ===========================================

# Domain configuration
DOMAIN=netloop.example.com

# Database
DB_USER=netloop
DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
DB_NAME=netloop

# JWT Secrets
JWT_SECRET=<GENERATE_32_CHAR_SECRET>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<GENERATE_32_CHAR_SECRET>
JWT_REFRESH_EXPIRES_IN=7d

# Settings Encryption (32 characters)
SETTINGS_ENCRYPTION_KEY=<GENERATE_32_CHAR_KEY>

# App URLs (will use DOMAIN)
CORS_ORIGIN=https://${DOMAIN},https://admin.${DOMAIN}
NEXT_PUBLIC_API_URL=https://${DOMAIN}/api
